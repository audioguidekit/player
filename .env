# Map tile provider API keys
# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and never committed.

# Mapbox — https://account.mapbox.com/access-tokens/
VITE_MAPBOX_API_KEY=

# Jawg Maps — https://www.jawg.io/lab/access-tokens
VITE_JAWG_API_KEY=

# MapTiler — https://cloud.maptiler.com/account/keys/
VITE_MAPTILER_API_KEY=

# CARTO basemaps are free and require no key.
